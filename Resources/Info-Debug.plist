<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleIdentifier</key>
    <string>com.yourname.pocketstudyremote</string>

    <key>CFBundleName</key>
    <string>Pocket Study Remote</string>

    <key>CFBundleDisplayName</key>
    <string>Pocket Study Remote</string>

    <!-- Debug: normal Dock app so windows/alerts can appear. Release uses Info.plist with LSUIElement. -->
    <key>LSUIElement</key>
    <false/>

    <key>LSBackgroundOnly</key>
    <false/>

    <key>CFBundleVersion</key>
    <string>1</string>

    <key>CFBundleShortVersionString</key>
    <string>1.0.0</string>

    <key>CFBundlePackageType</key>
    <string>APPL</string>

    <key>CFBundleExecutable</key>
    <string>$(EXECUTABLE_NAME)</string>

    <key>LSMinimumSystemVersion</key>
    <string>13.0</string>

    <key>NSAccessibilityUsageDescription</key>
    <string>Pocket Study Remote needs Accessibility access to send keyboard shortcuts to your apps when you press controller buttons.</string>

    <key>NSAppleEventsUsageDescription</key>
    <string>Pocket Study Remote uses AppleScript to control Spotify playback.</string>
</dict>
</plist>
