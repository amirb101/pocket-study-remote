<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Required: unique identifier matching your Apple Developer account -->
    <key>CFBundleIdentifier</key>
    <string>com.yourname.pocketstudyremote</string>

    <!-- App name shown in the menu bar tooltip and Activity Monitor -->
    <key>CFBundleName</key>
    <string>Pocket Study Remote</string>

    <key>CFBundleDisplayName</key>
    <string>Pocket Study Remote</string>

    <!-- Hides the app from the Dock — it lives in the menu bar only -->
    <key>LSUIElement</key>
    <true/>

    <!-- Prevents Spotlight from indexing the app bundle -->
    <key>LSBackgroundOnly</key>
    <false/>

    <key>CFBundleVersion</key>
    <string>1</string>

    <key>CFBundleShortVersionString</key>
    <string>1.0.0</string>

    <key>CFBundlePackageType</key>
    <string>APPL</string>

    <key>CFBundleExecutable</key>
    <string>$(EXECUTABLE_NAME)</string>

    <!-- Minimum macOS version: 13 Ventura (required for SMAppService, Swift Concurrency) -->
    <key>LSMinimumSystemVersion</key>
    <string>13.0</string>

    <!-- Accessibility permission usage description (shown in System Settings) -->
    <key>NSAccessibilityUsageDescription</key>
    <string>Pocket Study Remote needs Accessibility access to send keyboard shortcuts to your apps when you press controller buttons.</string>

    <!-- AppleScript usage description (shown when first running a script) -->
    <key>NSAppleEventsUsageDescription</key>
    <string>Pocket Study Remote uses AppleScript to control Spotify playback.</string>
</dict>
</plist>
